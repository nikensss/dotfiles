#!/usr/bin/env bash

function tag(){
  declare -A session_set
  while IFS= read -r s; do
    session_set["$s"]=1
  done <<< "$1"

  while IFS= read -r line; do
    local bn="${line##*/}"
    [[ -z "${session_set[$bn]}" ]] && printf '(repo) %s\n' "$line"
  done
}

function get_options() {
  local sessions
  sessions=$(tmux list-sessions -F '#S' 2>/dev/null)

  while IFS= read -r s; do
    [[ -n "$s" ]] && printf '(session) %s\n' "$s"
  done <<< "$sessions"

  for d in ~/repos/*/; do
    [[ -d "${d}.git" ]] && printf '%s\n' "${d%/}"
  done | tag "$sessions"
}

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(get_options | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected="${selected#* }"
selected_name="${selected##*/}"
selected_name="${selected_name//./_}"

if [[ -z $TMUX ]]; then
    tmux new-session -A -s "$selected_name" -c "$selected"
    exit 0
fi

tmux new-session -ds "$selected_name" -c "$selected" 2>/dev/null
tmux switch-client -t "$selected_name"
