#!/usr/bin/env bash

# Restore the Claude Code statusline setup for this machine.
#
# The statusline SCRIPT lives in the repo (.claude/statusline.sh) but the config
# that wires it up lives in ~/.claude/settings.json - a file Claude Code owns and
# rewrites, and which is NOT tracked in this repo. When settings.json is reset or
# a new machine is set up, the statusLine block vanishes with no source of truth.
#
# This script is that source of truth. It is idempotent - run it any time the
# statusline goes missing:
#   - symlinks ~/.claude/statusline.sh  -> repo/.claude/statusline.sh
#   - symlinks ~/.claude/CLAUDE.md      -> repo/AGENTS.md
#   - sets the statusLine block in ~/.claude/settings.json (only that key; every
#     other setting - permissions, model, theme - is left untouched)

set -euo pipefail

# Resolve the real repo dir even when invoked via the ~/bin symlink.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
repo_dir="$(cd "$script_dir/.." && pwd -P)"

claude_dir="$HOME/.claude"
settings="$claude_dir/settings.json"

# Canonical statusLine config - the single source of truth.
statusline_config='{
  "type": "command",
  "command": "~/.claude/statusline.sh",
  "padding": 0,
  "refreshInterval": 10
}'

mkdir -p "$claude_dir"

# link_file <target> <link>: point <link> at <target>, backing up anything real.
link_file() {
    local target="$1" link="$2"
    if [[ -L "$link" && "$(readlink "$link")" == "$target" ]]; then
        echo "  ok: $link already links to $target"
        return 0
    fi
    if [[ -e "$link" || -L "$link" ]]; then
        local bak="$link.bak.$(date +%Y%m%d%H%M%S)"
        echo "  backing up existing $link -> $bak"
        mv "$link" "$bak"
    fi
    ln -s "$target" "$link"
    echo "  linked: $link -> $target"
}

echo "Restoring Claude statusline from $repo_dir"
link_file "$repo_dir/.claude/statusline.sh" "$claude_dir/statusline.sh"
link_file "$repo_dir/AGENTS.md" "$claude_dir/CLAUDE.md"

if ! command -v jq >/dev/null 2>&1; then
    echo "  WARNING: jq not found - skipping settings.json merge." >&2
    echo "  Install jq, then re-run: $script_dir/$(basename "${BASH_SOURCE[0]}")" >&2
    exit 1
fi

# Start from {} if settings.json is missing/empty; back it up if it's invalid JSON.
if [[ ! -s "$settings" ]]; then
    echo '{}' > "$settings"
    chmod 600 "$settings"
elif ! jq empty "$settings" >/dev/null 2>&1; then
    bak="$settings.bak.$(date +%Y%m%d%H%M%S)"
    echo "  WARNING: $settings is not valid JSON - backing up to $bak and starting fresh" >&2
    mv "$settings" "$bak"
    echo '{}' > "$settings"
    chmod 600 "$settings"
fi

tmp="$(mktemp)"
jq --argjson sl "$statusline_config" '.statusLine = $sl' "$settings" > "$tmp"
mv "$tmp" "$settings"
chmod 600 "$settings"
echo "  set statusLine block in $settings"
echo "Done."
