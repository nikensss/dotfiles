#!/usr/bin/env bash

# Select a Linear ticket assigned to you, clone workmate for it (if needed),
# and switch to (or create) a tmux session named after the ticket ID.

[[ -z "$LINEAR_API_KEY" && -f ~/.env ]] && source ~/.env
LINEAR_API_KEY="${LINEAR_API_KEY:-$(cat ~/.config/linear/token 2>/dev/null)}"

if [[ -z "$LINEAR_API_KEY" ]]; then
    tmux display-message "tmux-linear-ticket: LINEAR_API_KEY not set (env or ~/.config/linear/token)"
    exit 1
fi

QUERY='{"query":"{ viewer { assignedIssues(filter: { completedAt: { null: true } }) { nodes { identifier title state { name } } } } }"}'

response=$(curl -sf -X POST https://api.linear.app/graphql \
    -H "Authorization: $LINEAR_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$QUERY")

if [[ -z "$response" ]]; then
    tmux display-message "tmux-linear-ticket: failed to reach Linear API"
    exit 1
fi

issues=$(echo "$response" | jq -r '.data.viewer.assignedIssues.nodes[] | "\(.identifier)\t[\(.state.name)]\t\(.title)"' 2>/dev/null)

if [[ -z "$issues" ]]; then
    tmux display-message "tmux-linear-ticket: no assigned issues found"
    exit 1
fi

selected=$(echo "$issues" | column -t -s $'\t' | fzf \
    --prompt="  Linear > " \
    --reverse \
    --height=100% \
    --no-sort)

if [[ -z "$selected" ]]; then
    exit 0
fi

ticket_id=$(echo "$selected" | awk '{print $1}')
repo_dir="$HOME/repos/$ticket_id"
workmate_dir="$HOME/repos/workmate"

if [[ ! -d "$repo_dir" ]]; then
    git clone "$(git -C "$workmate_dir" remote get-url origin)" "$repo_dir"

    cp "$workmate_dir/.env" "$repo_dir/.env"
    cp "$workmate_dir/shopify.app.toml" "$repo_dir/shopify.app.toml"

    # web/.env and web/frontend/.env are symlinks to ../.env in the source repo
    ln -s ../.env "$repo_dir/web/.env"
    ln -s ../.env "$repo_dir/web/frontend/.env"
fi

if ! tmux has-session -t="$ticket_id" 2>/dev/null; then
    tmux new-session -ds "$ticket_id" -c "$repo_dir" -n "code"
    tmux new-window -t "$ticket_id" -n "claude" -c "$repo_dir"
    tmux new-window -t "$ticket_id" -n "watch" -c "$repo_dir"
    tmux new-window -t "$ticket_id" -n "funnel" -c "$repo_dir"
    tmux select-window -t "$ticket_id:code"
    tmux send-keys -t "$ticket_id:code" "pnpm :ci && pnpm :build" Enter
fi

tmux switch-client -t "$ticket_id"
