#!/usr/bin/env bash

# Select a Linear ticket assigned to you.
# wm-* tickets:
#   - Dev Scoping: open a window in the shared "workmate" session
#   - All other: clone workmate, set up env files, create a dedicated session
# nai-* tickets:
#   - Dev Scoping: open a window in the shared "elc-teifi-apps" session
#   - All other: clone elc-teifi-apps into a dedicated dir, create a dedicated session

[[ -z "$LINEAR_API_KEY" && -f ~/.env ]] && source ~/.env
LINEAR_API_KEY="${LINEAR_API_KEY:-$(cat ~/.config/linear/token 2>/dev/null)}"

if [[ -z "$LINEAR_API_KEY" ]]; then
    tmux display-message "tmux-linear-ticket: LINEAR_API_KEY not set (env or ~/.config/linear/token)"
    exit 1
fi

QUERY='{"query":"{ viewer { assignedIssues(filter: { completedAt: { null: true } }) { nodes { identifier title state { name } branchName } } } }"}'

response=$(curl -sf -X POST https://api.linear.app/graphql \
    -H "Authorization: $LINEAR_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$QUERY")

if [[ -z "$response" ]]; then
    tmux display-message "tmux-linear-ticket: failed to reach Linear API"
    exit 1
fi

issues=$(echo "$response" | jq -r '.data.viewer.assignedIssues.nodes[] | "\(.identifier)\t[\(.state.name)]\t\(.title)\t\(.branchName)"' 2>/dev/null)

if [[ -z "$issues" ]]; then
    tmux display-message "tmux-linear-ticket: no assigned issues found"
    exit 1
fi

selected=$(echo "$issues" | cut -f1-3 | column -t -s $'\t' | fzf \
    --prompt="  Linear > " \
    --height=100% \
    --no-sort)

if [[ -z "$selected" ]]; then
    exit 0
fi

ticket_id=$(echo "$selected" | awk '{print $1}')
ticket_id_lower="${ticket_id,,}"
ticket_status=$(echo "$issues" | awk -F'\t' -v id="$ticket_id" '$1 == id { gsub(/^\[|\]$/, "", $2); print $2 }')
branch_name=$(echo "$issues" | awk -F'\t' -v id="$ticket_id" '$1 == id { print $4 }')

workmate_dir="$HOME/repos/workmate"
workmate_remote="git@github.com:Teifi-Digital/workmate.git"
elc_teifi_apps_dir="$HOME/repos/elc-teifi-apps"
elc_teifi_apps_remote="git@github.com:Teifi-Digital/elc-teifi-apps.git"

case "$ticket_id_lower" in
    wm-*)
        shared_remote="$workmate_remote"
        shared_dir="$workmate_dir"
        shared_session="workmate"
        ;;
    nai-*)
        shared_remote="$elc_teifi_apps_remote"
        shared_dir="$elc_teifi_apps_dir"
        shared_session="elc-teifi-apps"
        ;;
    *)
        tmux display-message "tmux-linear-ticket: unknown ticket prefix for '$ticket_id'"
        exit 1
        ;;
esac

ensure_shared_session() {
    if [[ ! -d "$shared_dir" ]]; then
        git clone "$shared_remote" "$shared_dir"
    fi

    if ! tmux has-session -t="$shared_session" 2>/dev/null; then
        tmux new-session -ds "$shared_session" -c "$shared_dir" -n "$shared_session"
        tmux send-keys -t "$shared_session:$shared_session" "pnpm :ci && pnpm :build" Enter
    fi
}

open_shared_session() {
    current_session=$(tmux display-message -p '#S')
    new_window=false

    if [[ "$current_session" == "$shared_session" ]]; then
        picker_window=$(tmux display-message -p '#{window_index}')
        if ! tmux list-windows -t "$shared_session" -F '#{window_name}' | grep -qxF "$ticket_id_lower"; then
            tmux new-window -d -t "$shared_session:" -n "$ticket_id_lower" -c "$shared_dir"
            new_window=true
        fi
        tmux select-window -t "$shared_session:=$ticket_id_lower"
        tmux kill-window -t "$shared_session:$picker_window"
    else
        if ! tmux list-windows -t "$shared_session" -F '#{window_name}' | grep -qxF "$ticket_id_lower"; then
            tmux new-window -t "$shared_session" -n "$ticket_id_lower" -c "$shared_dir"
            new_window=true
        fi
        tmux switch-client -t "$shared_session"
        tmux select-window -t "$shared_session:$ticket_id_lower"
    fi

    if [[ "$new_window" == "true" ]]; then
        sleep 0.2
        tmux send-keys -t "$shared_session:$ticket_id_lower" "claude" Enter
    fi
}

open_dedicated_session() {
    local repo_dir="$1"

    if ! tmux has-session -t="$ticket_id_lower" 2>/dev/null; then
        tmux new-session -ds "$ticket_id_lower" -c "$repo_dir" -n "nvim"
        tmux new-window -t "$ticket_id_lower" -n "claude" -c "$repo_dir"
        tmux new-window -t "$ticket_id_lower" -n "watch" -c "$repo_dir"
        tmux new-window -t "$ticket_id_lower" -n "funnel" -c "$repo_dir"
        tmux select-window -t "$ticket_id_lower:nvim"
        tmux send-keys -t "$ticket_id_lower:nvim" "pnpm :ci && pnpm :build" Enter
        tmux send-keys -t "$ticket_id_lower:claude" "claude" Enter
    fi

    tmux switch-client -t "$ticket_id_lower"
}

setup_repo_wm() {
    local repo_dir="$1"
    cp "$workmate_dir/.env" "$repo_dir/.env"
    cp "$workmate_dir/shopify.app.toml" "$repo_dir/shopify.app.toml"
    ln -s ../.env "$repo_dir/web/.env"
    ln -s ../.env "$repo_dir/web/frontend/.env"
}

setup_repo_nai() {
    local repo_dir="$1"

    # Root .env (used by docker-compose, vite loadEnv, and the per-app symlinks).
    cp "$elc_teifi_apps_dir/.env" "$repo_dir/.env"

    # Per-app Shopify CLI configs (gitignored). The repo has two apps; copy
    # whichever the shared dir has linked. Skip silently if missing.
    [[ -f "$elc_teifi_apps_dir/shopify.app.toml" ]] && cp "$elc_teifi_apps_dir/shopify.app.toml" "$repo_dir/shopify.app.toml"
    [[ -f "$elc_teifi_apps_dir/shopify.app.rms.toml" ]] && cp "$elc_teifi_apps_dir/shopify.app.rms.toml" "$repo_dir/shopify.app.rms.toml"

    # Backend apps load `dotenv/config` from cwd (`apps/web-{rms,talonone}/`)
    # so each needs its own .env. Symlink to the root .env to keep one source of truth.
    # Frontends don't need this — their vite config calls loadEnv(mode, workspaceRoot)
    # which reads from the root .env directly.
    ln -s ../../.env "$repo_dir/apps/web-rms/.env"
    ln -s ../../.env "$repo_dir/apps/web-talonone/.env"
}

if [[ "$ticket_status" == "Dev Scoping" ]]; then
    ensure_shared_session
    open_shared_session
else
    repo_dir="$HOME/repos/$ticket_id_lower"

    if [[ ! -d "$repo_dir" ]]; then
        git clone "$shared_remote" "$repo_dir"

        case "$ticket_id_lower" in
            wm-*)  setup_repo_wm "$repo_dir" ;;
            nai-*) setup_repo_nai "$repo_dir" ;;
        esac

        git -C "$repo_dir" checkout "$branch_name" 2>/dev/null || git -C "$repo_dir" checkout -b "$branch_name"
    fi

    open_dedicated_session "$repo_dir"
fi
